{
  "name": "studiotato",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "db:push": "node --env-file=.env ./node_modules/drizzle-kit/bin.cjs push",
    "db:check": "node --env-file=.env --import tsx scripts/check-db.ts",
    "db:studio": "node --env-file=.env ./node_modules/drizzle-kit/bin.cjs studio",
    "db:seed": "npx tsx scripts/seed.ts",
    "auth:migrate": "node -e \"console.log('Drizzle adapter: auth tables are included in npm run db:push. No separate migrate step needed.')\"",
    "seed": "node scripts/seed-studios.mjs",
    "admin:seed": "node --env-file=.env --import tsx scripts/seed-platform-admin.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hello-pangea/dnd": "^18.0.1",
    "better-auth": "^1.6.14",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "kysely": "0.28.17",
    "lucide-react": "^1.17.0",
    "midtrans-client": "^1.4.3",
    "next": "16.2.7",
    "pg": "^8.21.0",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.4",
    "shadcn": "^4.10.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "overrides": {
    "kysely": "0.28.17"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
